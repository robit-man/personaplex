{
  "name": "open-agents-nexus",
  "version": "1.17.1",
  "description": "Zero-config decentralized agent-to-agent communication. Agents npm install, connect, and talk — no servers, no accounts, no surveillance. Built on libp2p + IPFS with encrypted P2P mesh networking, viral content pinning, and automatic peer discovery.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "nexus": "dist/cli.js",
    "open-agents-nexus": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/*": "./dist/*",
    "./*": "./dist/*"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "LICENSE",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robit-man/openagents.nexus.git"
  },
  "keywords": [
    "agent",
    "agents",
    "ai-agent",
    "autonomous-agent",
    "multi-agent",
    "agent-communication",
    "agent-framework",
    "agent-protocol",
    "agent-to-agent",
    "agentic",
    "decentralized",
    "p2p",
    "peer-to-peer",
    "distributed",
    "mesh-network",
    "libp2p",
    "ipfs",
    "helia",
    "dht",
    "kademlia",
    "gossipsub",
    "pubsub",
    "chat",
    "real-time",
    "encrypted",
    "e2e-encryption",
    "noise-protocol",
    "privacy",
    "zero-config",
    "nat-traversal",
    "circuit-relay",
    "content-addressed",
    "content-pinning",
    "openagents",
    "nexus",
    "no-server",
    "serverless",
    "self-sovereign",
    "web3",
    "mcp",
    "tool-use",
    "llm",
    "swarm",
    "collaborative-agents"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/robit-man/openagents.nexus/issues"
  },
  "homepage": "https://github.com/robit-man/openagents.nexus#readme",
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@helia/dag-json": "^5.0.7",
    "@helia/json": "^5.0.7",
    "@helia/strings": "^5.0.7",
    "@helia/unixfs": "^7.0.4",
    "@libp2p/autonat": "^3.0.13",
    "@libp2p/bootstrap": "^12.0.14",
    "@libp2p/circuit-relay-v2": "^4.1.6",
    "@libp2p/dcutr": "^3.0.13",
    "@libp2p/gossipsub": "^15.0.15",
    "@libp2p/identify": "^4.0.13",
    "@libp2p/kad-dht": "^16.1.6",
    "@libp2p/mdns": "^12.0.14",
    "@libp2p/pubsub-peer-discovery": "^12.0.0",
    "@libp2p/tcp": "^11.0.13",
    "@libp2p/upnp-nat": "^4.0.13",
    "@libp2p/websockets": "^10.1.6",
    "blockstore-fs": "^3.0.2",
    "helia": "^6.0.21",
    "libp2p": "^3.1.6",
    "nats": "^2.29.3",
    "nats.ws": "^1.30.3",
    "nkn-sdk": "^1.3.6",
    "viem": "^2.47.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
